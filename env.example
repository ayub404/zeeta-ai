# Zeeta — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://zeeta_user:zeeta_pass@localhost:5432/zeeta_db

# JWT secret — change this to a long random string in production
SECRET_KEY=zeeta-dev-secret-change-in-production-use-openssl-rand-hex-32
